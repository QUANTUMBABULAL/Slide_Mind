{
  "name": "SlideMind",
  "description": "AI study workspace panel for ChatGPT project chats.",
  "version": "0.1.0",
  "manifest_version": 3,
  "action": {
    "default_title": "SlideMind",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": [
        "libs/pdf.min.js",
        "content/domWatcher.js",
        "content/uiInjector.js",
        "pdf/pdfState.js",
        "pdf/pdfEngine.js",
        "pdf/annotationLayer.js",
        "utils/fileHelpers.js",
        "utils/imageCapture.js",
        "utils/constants.js",
        "content/chatgptBridge.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/*", "content/*", "assets/*", "pdf/*", "utils/*"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}
